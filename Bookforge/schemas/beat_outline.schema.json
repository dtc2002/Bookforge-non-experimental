{
  "type": "object",
  "required": [
    "opening_condition",
    "inciting_incident",
    "first_major_turn",
    "midpoint_shift",
    "crisis",
    "climax",
    "resolution",
    "setup_payoff_chain",
    "beat_list"
  ],
  "properties": {
    "opening_condition": { "type": "string" },
    "inciting_incident": { "type": "string" },
    "first_major_turn": { "type": "string" },
    "midpoint_shift": { "type": "string" },
    "crisis": { "type": "string" },
    "climax": { "type": "string" },
    "resolution": { "type": "string" },

    "character_arc": {
      "type": "object",
      "required": ["start_state", "end_state"],
      "properties": {
        "start_state": { "type": "string" },
        "end_state": { "type": "string" }
      },
      "additionalProperties": false
    },

    "emotional_arc": {
      "type": "object",
      "required": ["start_feeling", "end_feeling"],
      "properties": {
        "start_feeling": { "type": "string" },
        "end_feeling": { "type": "string" }
      },
      "additionalProperties": false
    },

    "setup_payoff_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "setup",
          "promise_type",
          "introduced_by_beat",
          "payoff",
          "payoff_target",
          "required_by_chapter",
          "status"
        ],
        "properties": {
          "id": { "type": "string" },
          "setup": { "type": "string" },
          "promise_type": {
            "type": "string",
            "enum": [
              "plot",
              "emotional",
              "relationship",
              "mystery",
              "object",
              "worldbuilding",
              "theme"
            ]
          },
          "introduced_by_beat": {
            "type": "integer",
            "minimum": 1
          },
          "payoff": { "type": "string" },
          "payoff_target": {
            "type": "string",
            "enum": ["mandatory", "optional", "sequel_hook"]
          },
          "required_by_chapter": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": ["open", "paid_off", "deferred"]
          }
        },
        "additionalProperties": false
      }
    },

    "beat_list": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "beat_number",
          "label",
          "summary",
          "purpose",
          "escalation_level",
          "pressure_source",
          "pressure_change",
          "pressure_level",
          "consequence_if_failed"
        ],
        "properties": {
          "beat_number": {
            "type": "integer",
            "minimum": 1
          },
          "label": { "type": "string" },
          "summary": { "type": "string" },
          "purpose": { "type": "string" },
          "escalation_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "pressure_source": { "type": "string" },
          "pressure_change": {
            "type": "string",
            "enum": ["increase", "hold", "decrease"]
          },
          "pressure_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "consequence_if_failed": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}